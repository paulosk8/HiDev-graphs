# Configuración de Supabase para el inicio de sesión.
# Copia este archivo a `.env` y rellena los valores de tu proyecto de Supabase.
# (En Supabase: Project Settings → API → Project URL y "anon public" key.)
# La clave anónima es pública por diseño; la seguridad la impone Row-Level Security.

MAIN_VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
MAIN_VITE_SUPABASE_ANON_KEY=TU_CLAVE_ANON_PUBLICA
