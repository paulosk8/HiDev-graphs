{
  "name": "pedagograph",
  "version": "0.1.0",
  "description": "Organiza tu material pedagógico por conceptos reutilizables y visualiza sus relaciones.",
  "author": "Paulo Galarza",
  "license": "UNLICENSED",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "rebuild": "electron-rebuild -f -w better-sqlite3 -w node-pty",
    "postinstall": "electron-rebuild -f -w better-sqlite3 -w node-pty",
    "sembrar-demo": "esbuild scripts/sembrar-demo.ts --bundle --platform=node --format=cjs --external:js-yaml --outfile=node_modules/.cache/seed.cjs && node node_modules/.cache/seed.cjs",
    "build:mcp": "esbuild src/mcp/servidor.ts --bundle --platform=node --format=esm --outfile=out/mcp/pedagograph-mcp.mjs --banner:js=\"import{createRequire}from'node:module';const require=createRequire(import.meta.url);\"",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "archiver": "^8.0.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "cytoscape": "^3.34.0",
    "cytoscape-fcose": "^2.2.0",
    "js-yaml": "^5.2.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.6",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/archiver": "^8.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cytoscape": "^3.21.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "electron": "^41.7.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^7.0.0"
  }
}
